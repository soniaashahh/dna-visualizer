# --- Backend (server.js) — copy to .env and fill HF_TOKEN
# Run: npm run server   (in a second terminal while npm start runs the UI)

HF_TOKEN=
# HF_ESMFOLD_MODEL=facebook/esmfold_v1
# HF inference base (default: https://router.huggingface.co/hf-inference)
# HF_INFERENCE_BASE=https://router.huggingface.co/hf-inference
# PORT=5001

# --- Frontend (Create React App) — copy to .env.local if needed

# URL of the ESMFold proxy (must match server port; default http://localhost:5001)
# REACT_APP_ESMFOLD_BACKEND_URL=http://localhost:5001
